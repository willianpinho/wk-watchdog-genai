# wk-watchdog — example environment file
# -----------------------------------------------------------------------------
# Copy to `.env` (gitignored) for local dev, OR resolve secrets at runtime via
# 1Password CLI:
#     op run --env-file=.env -- make run
#
# Real secrets live ONLY in 1Password. This file carries placeholders and
# `op://` URI examples. DO NOT commit real credentials.
# -----------------------------------------------------------------------------

# --- Application ----------------------------------------------------------
WATCHDOG_ENV=local                                      # local | dev | prod
WATCHDOG_LOG_LEVEL=INFO                                 # DEBUG | INFO | WARN | ERROR
WATCHDOG_API_HOST=0.0.0.0
WATCHDOG_API_PORT=8000

# --- Storage --------------------------------------------------------------
# Local SQLite file. Tests use `sqlite+aiosqlite:///:memory:`.
WATCHDOG_DB_URL=sqlite+aiosqlite:///./data/watchdog.sqlite

# --- Intelligence layer (GenAI) -------------------------------------------
# Used by the SeverityClassifier (LLM-backed). Resolve at runtime via
# 1Password rather than pasting the literal key:
#   op run --env-file=.env -- make run
# Vault item: Personal / anthropic-watchdog / api-key
ANTHROPIC_API_KEY=op://Personal/anthropic-watchdog/api-key

# Per-minute token cap for the classifier; over the cap we force the
# deterministic rule-based fallback. Default 100k tokens / minute.
WATCHDOG_GENAI_TOKENS_PER_MINUTE_CAP=100000

# --- Self-observability ---------------------------------------------------
# Leave blank in dev to log spans to stdout.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=wk-watchdog-api
