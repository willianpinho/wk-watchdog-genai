{
  "annotations": {
    "list": []
  },
  "editable": false,
  "graphTooltip": 0,
  "id": null,
  "uid": "wk-watchdog",
  "title": "wk-watchdog overview",
  "tags": [
    "watchdog",
    "observability"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Event ingestion rate (per second)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by (level) (rate(events_ingested_total[1m]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Anomalies detected (per minute)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum by (severity) (increase(anomalies_detected_total[1m]))",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Webhook delivery latency p95 (seconds)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, outcome) (rate(webhook_delivery_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "GenAI token usage (per minute)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum by (kind) (increase(genai_tokens_total[1m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ]
    }
  ]
}
